# ── Secrets / environment ────────────────────────────────────────────────
# Never commit real secrets. Keep .env.example tracked as the template.
.env
.env.*
!.env.example

# ── Python bytecode / caches ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ── Virtual environments ─────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# ── Packaging / build artifacts ──────────────────────────────────────────
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# ── Test / coverage / type-check caches ──────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# ── Cognee / local data stores ───────────────────────────────────────────
# On-device graph/vector stores and cached artifacts should stay local.
.cognee_system/
.data_storage/
cognee_data/
data/
*.db
*.sqlite
*.sqlite3
*.duckdb
*.lance/
chroma/
.chromadb/

# ── Logs ─────────────────────────────────────────────────────────────────
*.log
logs/

# ── Jupyter ──────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── OS / editor cruft ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
