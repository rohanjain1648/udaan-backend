# ── Groq ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Cognee LLM — OpenAI-compatible endpoint pointing at Groq ─────────────────
LLM_API_KEY=gsk_your_key_here
LLM_PROVIDER=openai
LLM_ENDPOINT=https://api.groq.com/openai/v1
LLM_MODEL=openai/llama-3.3-70b-versatile
COGNEE_SKIP_CONNECTION_TEST=true

# ── Cognee Embeddings — Gemini API (free tier, no local binary deps) ──────────
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini/gemini-embedding-001
EMBEDDING_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
EMBEDDING_DIMENSIONS=3072

# ── Storage (defaults to .cognee_system/ in current dir) ─────────────────────
# COGNEE_DATA_DIR=D:/cognee-data
